# Gmail Configuration
# -------------------
# Your Gmail address (the account you'll send from)
GMAIL_ADDRESS=PASTE_YOUR_GMAIL_HERE

# Your Gmail App Password (NOT your regular password!)
# See README.md for instructions on getting an App Password
GMAIL_APP_PASSWORD=PASTE_YOUR_APP_PASSWORD_HERE

# The email address to send alerts to
RECIPIENT_EMAIL=PASTE_RECIPIENT_EMAIL_HERE
